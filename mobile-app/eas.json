{
  "build": {
    "development": {
      "channel": "development",
      "autoIncrement": false,
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "key": "dev-android-v4-postinstall-prebuild"
      }
    },
    "development:driver": {
      "extends": "development",
      "env": {
        "APP_VARIANT": "driver"
      }
    },
    "development:rider": {
      "extends": "development",
      "env": {
        "APP_VARIANT": "rider"
      }
    },
    "simulator": {
      "channel": "simulator",
      "autoIncrement": false,
      "developmentClient": true,
      "ios": {
        "simulator": true
      },
      "distribution": "internal"
    },
    "preview": {
      "channel": "preview",
      "autoIncrement": false,
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "distribution": "internal"
    },
    "preview:driver": {
      "extends": "preview",
      "env": {
        "APP_VARIANT": "driver"
      }
    },
    "preview:rider": {
      "extends": "preview",
      "env": {
        "APP_VARIANT": "rider"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": false,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production:driver": {
      "extends": "production",
      "env": {
        "APP_VARIANT": "driver"
      }
    },
    "production:rider": {
      "extends": "production",
      "env": {
        "APP_VARIANT": "rider"
      }
    },
    "production-apk:driver": {
      "extends": "production:driver",
      "android": {
        "buildType": "apk"
      }
    },
    "production-apk:rider": {
      "extends": "production:rider",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "../serviceaccount.json",
        "track": "internal"
      }
    }
  },
  "cli": {
    "version": ">= 0.50.0",
    "requireCommit": true,
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false
  }
}
